---
import Default from '../../../../layouts/Default.astro';

const breadcrumbs = [
  { label: 'chris-park-1004', href: '/' },
  { label: 'projects/ci-cd', href: '/projects/ci-cd/' },
  { label: 'jenkins', href: '/projects/ci-cd/jenkins/' },
  { label: 'service-account' },
];
---

<Default
  title="Jenkins / Service Account — CI/CD Pipeline"
  description="Running Jenkins as a dedicated `jenkins` local user with the minimum required privileges on Windows 11 Home."
  breadcrumbs={breadcrumbs}
>
  <div class="header">
    <div>
      <div class="prompt">$ cat service-account.md</div>
      <h1>Service Account</h1>
      <div class="subtitle">Dedicated `jenkins` local user · privilege isolation · `SeServiceLogonRight` via `secedit`</div>
    </div>
    <div class="header-meta">
      <div class="row">status: <b style="color:var(--yellow)">● writing</b></div>
    </div>
  </div>

  <div class="stage" style="--accent: var(--yellow)">
    <div class="stage-head">
      <div>
        <div class="stage-meta">
          <span class="id">draft</span>
          <span class="badge b-yellow"><span class="badge-dot"></span>writing</span>
        </div>
        <div class="stage-name">Documentation in progress</div>
      </div>
    </div>
    <div class="stage-body">
      <p>Planned content:</p>
      <ul style="margin-top: 12px;">
        <li><span class="check" style="color:var(--yellow)">○</span><span>Why a dedicated service account (blast-radius reduction if Jenkins is compromised)</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span>Creating a non-admin local user on Windows 11 Home</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span>Granting <code>SeServiceLogonRight</code> via <code>secedit</code> (Home edition lacks <code>secpol.msc</code>)</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span>Switching Jenkins service to run as the new user</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span>Verifying with <code>Get-CimInstance Win32_Service</code></span></li>
      </ul>
    </div>
  </div>

  <div style="margin-top: 24px; font-family: 'JetBrains Mono', monospace; font-size: 12px;">
    <a href="/projects/ci-cd/jenkins/" style="color: var(--text-dim);">← back to Jenkins</a>
  </div>
</Default>
