---
import Default from '../../../../layouts/Default.astro';

const breadcrumbs = [
  { label: 'chris-park-1004', href: '/' },
  { label: 'projects/ci-cd', href: '/projects/ci-cd/' },
  { label: 'jenkins', href: '/projects/ci-cd/jenkins/' },
  { label: 'checks-api' },
];
---

<Default
  title="Jenkins / Checks API — CI/CD Pipeline"
  description="Per-stage check results pushed to GitHub PR via the Checks API: rich UI, beyond simple commit statuses."
  breadcrumbs={breadcrumbs}
>
  <div class="header">
    <div>
      <div class="prompt">$ cat checks-api.md</div>
      <h1>Checks API</h1>
      <div class="subtitle">Rich PR status display · per-stage results · branch protection-ready</div>
    </div>
    <div class="header-meta">
      <div class="row">status: <b style="color:var(--yellow)">● writing</b></div>
    </div>
  </div>

  <div class="stage" style="--accent: var(--yellow)">
    <div class="stage-head">
      <div>
        <div class="stage-meta">
          <span class="id">draft</span>
          <span class="badge b-yellow"><span class="badge-dot"></span>writing</span>
        </div>
        <div class="stage-name">Documentation in progress</div>
      </div>
    </div>
    <div class="stage-body">
      <p>Planned content:</p>
      <ul style="margin-top: 12px;">
        <li><span class="check" style="color:var(--yellow)">○</span><span>Commit Statuses vs. Checks API: why the latter for rich feedback</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span>Required plugins: Checks API plugin (interface) + GitHub Checks plugin (concrete publisher)</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span>The "No suitable checks publisher found" gotcha</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span><code>publishChecks</code> step usage in a stage</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span>Markdown summary + text body in check details</span></li>
        <li><span class="check" style="color:var(--yellow)">○</span><span>Branch protection that requires checks to pass before merge</span></li>
      </ul>
    </div>
  </div>

  <div style="margin-top: 24px; font-family: 'JetBrains Mono', monospace; font-size: 12px;">
    <a href="/projects/ci-cd/jenkins/" style="color: var(--text-dim);">← back to Jenkins</a>
  </div>
</Default>
