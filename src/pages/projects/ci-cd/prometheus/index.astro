---
import Default from '../../../../layouts/Default.astro';

const breadcrumbs = [
  { label: 'chris-park-1004', href: '/' },
  { label: 'projects/ci-cd', href: '/projects/ci-cd/' },
  { label: 'prometheus' },
];

interface Metric {
  name: string;
  type: 'gauge' | 'counter' | 'summary';
  meaning: string;
  panels: string;
}

// Jenkins Overview dashboard — scoped by jenkins_job=~"Jenkins-Test-Pipeline/.*"
const buildMetrics: Metric[] = [
  {
    name: 'default_jenkins_up',
    type: 'gauge',
    meaning: 'Controller liveness. 1 = the Jenkins controller is reachable and exporting.',
    panels: 'Jenkins Status',
  },
  {
    name: 'default_jenkins_builds_health_score',
    type: 'gauge',
    meaning: "Per-job weather score (0–100). Averaged across pipelines for the headline health number.",
    panels: 'Jenkins Job Health',
  },
  {
    name: 'default_jenkins_builds_last_build_result_ordinal',
    type: 'gauge',
    meaning: 'Result code of the most recent build (see result codes →). Counted by value to derive the Total / Successful / Failed / Aborted / Unstable tiles.',
    panels: 'Total / Successful / Failed / Aborted / Unstable Jobs · Registered Pipelines',
  },
  {
    name: 'default_jenkins_builds_last_build_duration_milliseconds',
    type: 'gauge',
    meaning: 'Wall-clock duration of the last build per pipeline+branch.',
    panels: 'Registered Pipelines (Build Duration)',
  },
  {
    name: 'default_jenkins_builds_last_build_start_time_milliseconds',
    type: 'gauge',
    meaning: 'Epoch-ms start time of the last build. Rendered as the Last Build Time column.',
    panels: 'Registered Pipelines (Last Build Time)',
  },
  {
    name: 'default_jenkins_builds_duration_milliseconds_summary_count',
    type: 'summary',
    meaning: 'Cumulative build count, split by the status label (SUCCESS / FAILURE / …). increase() over 1d gives the weekly activity bars.',
    panels: 'Weekly Build Activity by Pipeline × Result',
  },
  {
    name: 'default_jenkins_builds_last_stage_duration_milliseconds_summary',
    type: 'summary',
    meaning: 'Per-stage duration summary. sum / count by(stage) yields the average duration of each pipeline stage (Build, Lint, Test, …).',
    panels: 'Pipeline Stage Avg Duration',
  },
];

// Server Resources dashboard — scoped by job="jenkins"
const systemMetrics: Metric[] = [
  {
    name: 'vm_cpu_load',
    type: 'gauge',
    meaning: 'Process CPU load (0–1, shown ×100 as %). Drives both the instant tile and the trend line.',
    panels: 'CPU Load · CPU Load Over Time',
  },
  {
    name: 'vm_memory_heap_usage',
    type: 'gauge',
    meaning: 'Heap utilization ratio (0–1). Shown ×100 on the radial gauge.',
    panels: 'Heap Memory Usage',
  },
  {
    name: 'vm_memory_heap_used / heap_max',
    type: 'gauge',
    meaning: 'Used vs. configured-max heap, in bytes. Plotted together against the Xmx ceiling.',
    panels: 'JVM Memory',
  },
  {
    name: 'vm_memory_non_heap_used',
    type: 'gauge',
    meaning: 'Non-heap memory (metaspace, code cache) in bytes.',
    panels: 'JVM Memory',
  },
  {
    name: 'jvm_threads_current / peak',
    type: 'gauge',
    meaning: 'Live thread count and the peak since JVM start.',
    panels: 'JVM Threads',
  },
  {
    name: 'jvm_threads_state',
    type: 'gauge',
    meaning: 'Thread count broken down by state (RUNNABLE, WAITING, TIMED_WAITING, BLOCKED, …).',
    panels: 'JVM Thread States',
  },
  {
    name: 'jvm_threads_deadlocked',
    type: 'gauge',
    meaning: 'Number of deadlocked threads. Anything above 0 turns the tile red.',
    panels: 'Deadlocked Threads',
  },
  {
    name: 'jvm_gc_collection_seconds_sum',
    type: 'counter',
    meaning: 'Cumulative GC time per collector (G1 Young / Old / Concurrent). rate() gives GC pause time per second.',
    panels: 'GC Pause Time / sec',
  },
  {
    name: 'vm_file_descriptor_ratio_x100_window_5m',
    type: 'summary',
    meaning: 'Open file descriptors as a percentage of the OS limit (×100, 5m window).',
    panels: 'File Descriptor Usage',
  },
];

const totalMetrics = buildMetrics.length + systemMetrics.length;

const resultCodes = [
  { code: '0', label: 'SUCCESS', color: 'green' },
  { code: '1', label: 'UNSTABLE', color: 'yellow' },
  { code: '2', label: 'FAILURE', color: 'red' },
  { code: '3', label: 'NOT_BUILT', color: 'dim' },
  { code: '4', label: 'ABORTED', color: 'dim' },
];
---

<Default
  title="Prometheus — CI/CD Pipeline"
  description="What flows from Jenkins to Grafana Cloud: the metric catalog behind the Jenkins Overview and Server Resources dashboards, mapped to the panels that consume each series."
  breadcrumbs={breadcrumbs}
>

  <!-- header -->
  <div class="header">
    <div>
      <div class="prompt">$ curl -s localhost:9090/api/v1/label/__name__/values</div>
      <h1>Prometheus</h1>
      <div class="subtitle">Pull-based metrics · Docker on Jenkins host · remote_write to Grafana Cloud Mimir</div>
    </div>
    <div class="header-meta">
      <div class="row">runtime: <b>Docker</b></div>
      <div class="row">scrape: <b>120s</b></div>
      <div class="row">status: <b style="color:var(--green)">● deployed</b></div>
    </div>
  </div>

  <!-- summary -->
  <div class="summary">
    <div><div class="k">Metric families</div><div class="v blue">{totalMetrics}</div></div>
    <div><div class="k">Dashboards fed</div><div class="v purple">2</div></div>
    <div><div class="k">Scrape period</div><div class="v green">120s</div></div>
    <div><div class="k">Inbound ports</div><div class="v yellow">0</div></div>
  </div>

  <!-- main grid -->
  <div class="grid">
    <div>

      <!-- pipeline / data flow -->
      <div class="section-label">── ./pipeline</div>

      <div class="stage" style="--accent: var(--blue); margin-bottom: 28px;">
        <div class="stage-body">
          <p>
            All metrics originate from the <b>Jenkins Prometheus plugin</b> running with its default
            configuration — endpoint <code>/prometheus</code>, namespace <code>default</code>, 120s
            collection period. A Prometheus container on the Jenkins host scrapes
            <code>host.docker.internal:8080/prometheus/</code>, then a single <code>remote_write</code>
            block ships everything to Grafana Cloud Mimir. No relabel filtering — what is scraped is what
            Grafana sees. The local endpoint is bound to <code>localhost</code> only, so nothing is exposed inbound.
          </p>
          <div class="stack-tags" style="margin-top: 14px;">
            <span class="chip">Jenkins plugin (default)</span>
            <span class="chip">→ scrape 120s</span>
            <span class="chip">→ remote_write</span>
            <span class="chip">→ Grafana Cloud Mimir</span>
          </div>
        </div>
      </div>

      <!-- metric catalog -->
      <div class="section-label">── ./metrics</div>

      <!-- CI / build group -->
      <div class="stage" style="--accent: var(--green); margin-bottom: 14px;">
        <div class="stage-head">
          <div>
            <div class="stage-meta">
              <span class="id">group_01</span>
              <span class="badge b-green"><span class="badge-dot"></span>CI / build</span>
            </div>
            <div class="stage-name">Jenkins Overview</div>
            <div class="stage-sub">scope: jenkins_job=~"Jenkins-Test-Pipeline/.*"</div>
          </div>
          <div class="stage-dur">{buildMetrics.length} families</div>
        </div>
        <div class="stage-body">
          <ul>
            {buildMetrics.map((m) => (
              <li>
                <span class="check" style="color:var(--green)">▸</span>
                <span style="display:flex; flex-direction:column; gap:3px;">
                  <span style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                    <code>{m.name}</code>
                    <span class="chip">{m.type}</span>
                  </span>
                  <span style="color:var(--text-dim); font-size:12.5px; line-height:1.55;">{m.meaning}</span>
                  <span style="color:var(--text-faint); font-size:11px; font-family:'JetBrains Mono', monospace;">→ {m.panels}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- JVM / system group -->
      <div class="stage" style="--accent: var(--purple);">
        <div class="stage-head">
          <div>
            <div class="stage-meta">
              <span class="id">group_02</span>
              <span class="badge b-purple"><span class="badge-dot"></span>JVM / system</span>
            </div>
            <div class="stage-name">Server Resources</div>
            <div class="stage-sub">scope: job="jenkins"</div>
          </div>
          <div class="stage-dur">{systemMetrics.length} families</div>
        </div>
        <div class="stage-body">
          <ul>
            {systemMetrics.map((m) => (
              <li>
                <span class="check" style="color:var(--purple)">▸</span>
                <span style="display:flex; flex-direction:column; gap:3px;">
                  <span style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                    <code>{m.name}</code>
                    <span class="chip">{m.type}</span>
                  </span>
                  <span style="color:var(--text-dim); font-size:12.5px; line-height:1.55;">{m.meaning}</span>
                  <span style="color:var(--text-faint); font-size:11px; font-family:'JetBrains Mono', monospace;">→ {m.panels}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>

    <!-- right rail -->
    <div class="rail">

      <div class="section-label">── ./context</div>

      <div class="card">
        <div class="card-label">why prometheus</div>
        <p style="font-size: 12.5px; color: var(--text-dim); line-height: 1.6; margin: 0;">
          The Jenkins plugin exposes a ready-made <code>/prometheus</code> endpoint, so the gap between "Jenkins is up" and "I have a dashboard" is just one container plus one scrape job. No custom exporters, no instrumentation code.
        </p>
        <p style="font-size: 12.5px; color: var(--text-dim); line-height: 1.6; margin: 10px 0 0;">
          Running in Docker on the Jenkins host keeps scrape latency near-zero, and binding to <code>localhost</code> means the controller never exposes metrics outside the machine.
        </p>
      </div>

      <div class="card">
        <div class="card-label">result codes</div>
        <p style="font-size: 12px; color: var(--text-dim); line-height: 1.55; margin: 0 0 12px;">
          Values of <code>last_build_result_ordinal</code>, counted to build the job-status tiles:
        </p>
        <div style="display:flex; flex-direction:column; gap:7px; font-family:'JetBrains Mono', monospace; font-size:12px;">
          {resultCodes.map((r) => (
            <div style="display:flex; align-items:center; gap:10px;">
              <span style="color:var(--text-faint); width:14px;">{r.code}</span>
              <span class={`badge b-${r.color}`}><span class="badge-dot"></span>{r.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="card">
        <div class="card-label">stack</div>
        <div class="stack-group">
          <div class="cat">Runtime</div>
          <div class="stack-tags">
            <span class="stack-tag">Prometheus 2.x</span>
            <span class="stack-tag">Docker</span>
          </div>
        </div>
        <div class="stack-group">
          <div class="cat">Source</div>
          <div class="stack-tags">
            <span class="stack-tag">Jenkins Prometheus plugin</span>
            <span class="stack-tag">host.docker.internal</span>
          </div>
        </div>
        <div class="stack-group">
          <div class="cat">Sink</div>
          <div class="stack-tags">
            <span class="stack-tag">remote_write</span>
            <span class="stack-tag">Grafana Cloud Mimir</span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-label">related</div>
        <div style="display: flex; flex-direction: column; gap: 8px; font-family: 'JetBrains Mono', monospace; font-size: 12px;">
          <a href="/projects/ci-cd/grafana/" style="color: var(--purple);">→ Grafana dashboards</a>
          <a href="/projects/ci-cd/jenkins/" style="color: var(--green);">→ Jenkins component</a>
          <a href="/projects/ci-cd/" style="color: var(--text-dim);">← back to project</a>
        </div>
      </div>
    </div>
  </div>

</Default>
