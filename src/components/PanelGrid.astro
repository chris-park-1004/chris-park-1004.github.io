---
const PROM = '/projects/ci-cd/prometheus/';

export interface Src { label: string; anchor: string; }
export interface Panel {
  name: string;
  viz: 'stat' | 'gauge' | 'table' | 'timeseries' | 'barchart';
  meaning: string;
  img: string;
  srcs: Src[];
}

interface Props {
  panels: Panel[];
  accent: string;
}

const { panels, accent } = Astro.props;
---

<div class="panel-grid">
  {panels.map((p) => (
    <div class="panel-card" style={`--accent: var(--${accent})`}>
      <div class="panel-shot">
        <img
          src={`/img/grafana/${p.img}`}
          alt={`${p.name} panel`}
          loading="lazy"
          onerror="this.remove(); this.parentElement.classList.add('shot-pending');"
        />
      </div>
      <div class="panel-body">
        <div class="panel-top">
          <div class="panel-name">{p.name}</div>
          <span class="chip">{p.viz}</span>
        </div>
        <p class="panel-meaning">{p.meaning}</p>
        <div class="panel-srcs">
          {p.srcs.map((s) => (
            <a class="chip" href={`${PROM}#${s.anchor}`} title="View this metric in the Prometheus catalog">
              <code>{s.label}</code>
            </a>
          ))}
        </div>
      </div>
    </div>
  ))}
</div>
